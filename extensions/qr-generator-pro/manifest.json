{
  "manifest_version": 3,
  "name": "QR Generator Pro",
  "version": "1.0.0",
  "description": "Мгновенное создание QR-кодов для текущей страницы или любого текста с кастомизацией дизайна",
  "permissions": ["activeTab", "contextMenus", "storage"],
  "action": {
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Создать QR-код"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+Q",
        "mac": "Command+Shift+Q"
      },
      "description": "Открыть генератор QR-кодов"
    }
  }
}
